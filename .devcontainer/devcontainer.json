{
    "name": "Laba",
    "build" : {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cmake-tools",
                "llvm-vs-code-extensions.vscode-clangd",
                "tomoki1207.pdf",
                "james-yu.latex-workshop"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "terminal.integrated.profiles.linux": {
                    "bash": {
                        "path": "/bin/bash"
                    }
                },
                "clangd.path": "clangd"
            }
        }
    },
    "postCreateCommand": "apt-get update && apt-get install -y texlive-latex-base texlive-lang-cyrillic texlive-latex-extra && rm -rf /var/lib/apt/lists/*"
}